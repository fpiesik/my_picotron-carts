:: main.lua
--[[pod_format="raw",created="2025-08-15 18:45:21",modified="2025-08-29 20:59:38",revision=40]]
bdg = {
	x = 480 / 2 - (64 * 2) / 2,
	y = 50,
	w = 64, --width
	h = 64, --heigth
	s = 2, -- scale
	f = 3, -- frame size
	nb = 7, -- number of badges
	b = 1, -- current badge
}

colors = {
	bckA = 5,
	frm = 12,
	bckB = 7,
	cntnt = 9,
}

function _update()
 if btnp(0) then
 	bdg.b -=	1
 	if bdg.b <= 0 then bdg.b = bdg.nb end
 end
 if btnp(1) then
 	bdg.b +=	1
 	if bdg.b > bdg.nb then bdg.b = 1 end
 end
end

function _draw()
	local x = bdg.x
	local y = bdg.y
	local w = bdg.w
	local h = bdg.h
	local s = bdg.s
	local f = bdg.f
	local b = bdg.b
	
	rectfill(x, y, x + w * s, y + h * s, colors.bckA)
	circfill(x + w * s / 2, y + h * s / 2, w, colors.frm)
	circfill(x + w * s / 2, y + h * s / 2, w-f*2, colors.bckB)
	sspr(b, 0, 0, w, h, x, y, w* 2, h * 2)
end
