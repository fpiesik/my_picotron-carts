:: scenes/hub.lua
--[[pod_format="raw",created="2026-04-15 07:50:22",modified="2026-04-18 06:01:20",revision=5]]
function create_hub_scene()
  local hub = {
    items = {
      { key = "dodger", label = "Play Dodger" },
      { key = "collector", label = "Play Collector" },
      { key = "koffer", label = "Play Koffer" }
    },
    selected = 1,
    input_lock = false
  }

  function hub:init(app)
  end

  function hub:update(app)
    local input = app.input

    if not input.down and not input.up then
      self.input_lock = false
    end

    if not self.input_lock then
      if input.down then
        self.selected = self.selected + 1
        if self.selected > #self.items then
          self.selected = 1
        end
        self.input_lock = true
      elseif input.up then
        self.selected = self.selected - 1
        if self.selected < 1 then
          self.selected = #self.items
        end
        self.input_lock = true
      elseif input.action then
        local chosen = self.items[self.selected]
        app.scene_manager:switch(chosen.key)
      end
    end
  end

  function hub:draw(app)
    cls(1)

    print("MEGAGAME HUB", 40, 12, 7)
    print("Coins: "..tostr(app.save.data.coins or 0), 40, 24, 10)

    local y = 50
    for i=1,#self.items do
      local item = self.items[i]
      local prefix = "  "
      if i == self.selected then
        prefix = "> "
      end

      local hs = app.save.data.highscores[item.key] or 0
      print(prefix..item.label, 30, y, 7)
      print("Highscore: "..tostr(hs), 110, y, 6)

      y = y + 16
    end

    print("X: select", 30, 120, 6)
  end

  function hub:leave(app)
  end

  return hub
end
