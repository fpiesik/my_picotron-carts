--[[pod_format="raw",created="2025-02-18 20:02:19",modified="2025-05-12 15:41:17",revision=1321]]
input={
	recbuff={},
	drw_keyin=function(s,t)
		local keys={"z","s","x","d","c","v","g","b","h","n","j","m",","}
		for k=1,#keys do
			if key(keys[k])==true then 
				?k
			end
		end
		for i,n in ipairs(s.recbuff) do
    		print("note "..i..": hoehe="..n[1].." lautstaerke="..n[2])
    	end
	end,
	rec=function(s,t)
		local tick=stat(400 + t-1,11)
		local t_r=spd --ticks per row
		local row=row_t[t]
		local keys={"z","s","x","d","c","v","g","b","h","n","j","m",","}
		for k=1,#keys do
			if keyp(keys[k])==true then 
				?k
				add(s.recbuff, {k, tick})
			end
		end
	end
}
:: keys.lua
--[[pod_format="raw",created="2025-02-16 10:22:30",modified="2025-05-12 15:41:17",revision=1773]]
keys = {
	w=13,
	h=40,
	n_oct=2, --number of octaves
	s_wht={0,2,4,5,7,9,11,12,14,16,17,19,21,23,24},
	blk={1,3,6,8,10,13,15,18,20,22},
	blk_off={0,0,1,1,1,2,2,3,3,3}, --offset of the black keys
	non={0,0,0,0,0,0,0,0}, --note on
	pitch={0,0,0,0,0,0,0,0},
	a={1,1,1,0,0,0,0,1}, --track is active
	
	upd=function(s,t)
		if s.a[t]==1 then
			s.pitch[t] = (track_p[t]+12)%(s.n_oct*12) 
			if track_p[t]!=255 and track_p[t]!=0 then
				s.non[t]=1
			else
				s.non[t]=0
			end
		end
	end,
	drw_keys=function(s,x,y) -- horizontal keyboard
		h=s.h
		w=s.w
		c_woff=6
		c_on=4
		c_boff=0
		if 1==1 then
			for k = 0, 14 do
				rectfill(x+w*k-w/2+1, y, x+w*k+w/2-1,y+h, c_woff)
			end
			for k = 1, #s.blk do
				--if self.blk_off[k]==1
				off=s.blk_off[k]*w/2
				rectfill(x+w*s.blk[k]/2-w/2+off+3, y, x+w*s.blk[k]/2+w/2+off-3,y+h/2, c_boff)
			end
		end
	end,
	drw_ftre=function(s,t,x,y) --draw future
		local w=s.w
		local za=9 
		local cl=7
		local len=track_read(t).len
		local tick=stat(400 + t-1,11)
		local t_r=spd --ticks per row
		for r=0,8 do
			local ya=y-r*za+za*(tick%t_r)/t_r
			local yb=y-r*za-za+za*(tick%t_r)/t_r
			local pitch=track_read(track_c[t]).pitches[r+1+row[t]]
			--?"test "..track_row_read(track-1,row).pitch,x,y+row*za,cl
			if r+row[t] < len and pitch != 255 then 
				--?"test2 "..pitch,x,y-r*za-za+za*(tick%t_r)/t_r+2,cl
				for k = 0, 15 do
					if (pitch+12)%24==s.s_wht[k+1] then
						rectfill(x+w*k-w/2+1, y-r*za+za*(tick%t_r)/t_r, x+w*k+w/2-1,y-r*za-za+za*(tick%t_r)/t_r, c_on)
					end
				end
				for k = 0, 10 do
					if((pitch+12)%24==s.blk[k+1]) then
						rectfill(x+w*k+s.blk_off[k+1]*w+1, ya, x+w*k+s.blk_off[k+1]*w+w-1,yb, c_on)
					end
				end	
			end
		end
	end,
	drw_pitch=function(s,t,x,y) -- horizontal keyboard
		h=s.h/2
		w=s.w
		c_woff=6
		c_on=4
		c_boff=0
		if s.a[t]==1 then
			for k = 0, 15 do
				if(s.pitch[t]==s.s_wht[k+1] and s.non[t]==1)then
					rectfill(x+w*k-w/2+1, y+h, x+w*k+w/2-1,y+h*2, c_on)
				end
			end		
			for k = 0, 10 do
				if(s.pitch[t]==s.blk[k+1] and s.non[t]==1) then
					rectfill(x+w*k+s.blk_off[k+1]*w+1, y, x+w*k+s.blk_off[k+1]*w+w-1,y+h, c_on)
				--if(self.s_blcks[self.pitch[t]+1]==1 and self.non==1) then
					--if(self.pitch[t]==self.blk[k+1] and self.non==1)rectfill(x[t]+s*k-s/2+1, y[t]+h, x[t]+s*k+s/2-1,y[t]+h*2, c_on)
					--if(self.s_wht[k+1]<self.s_scl[k+1])rectfill(-s/2+x[t]+s*(k+1)-s/2+1, y[t],-s/2+x[t]+s*(k+1)+s/2-1,y[t]+h/2, c_on)
					--if(self.s_wht[k+1]>self.s_scl[k+1])rectfill(-s/2+x[t]+s*k-s/2+1, y[t],-s/2+x[t]+s*k+s/2-1,y[t]+h/2, c_on)
				end
			end
		end
	end
}
:: main.lua
--[[pod_format="raw",created="2025-02-09 11:08:47",modified="2025-05-12 15:41:17",revision=1678]]
xkeya=20
ykeya=70
xkeyb=270
ykeyb=100
xgit=20
ygit=150
xbss=20
ybss=210


dev = fstat"/ram/pancelor.txt" and env().corun_program
dev_stats = dev

local function include_lib(name)
	if (dev) cp("/appdata/system/"..name,"/ram/cart/"..name)
	include(name)
end


include_lib "lib/pq.lua"

include "sfxdata.lua"
include "game.lua"
include "score.lua"
include "keys.lua"
include "guitar.lua"
include "bass.lua"
include "input.lua"
pq("dev",dev)

function _init()
	for i=0,10 do
		track_write(i,spd)
	end
 	score:init()
 	music(0)
end


function _update()
	for i=1,8 do
		upd_sfxst(i)
	end
	keys:upd(1)
	keys:upd(2)
	keys:upd(3)
	keys:upd(8)
	guitar:upd(8)
	bass:upd(1)

	--upd_btn()
	--rkeys:upd(1)
	--keys:upd(8)
	--score:t_nte()
end

function _draw()
	cls(19)
	--map()
	--keys:drw_keys(1)
	keys:drw_ftre(8,xkeyb,100)
	guitar:drw_neck(xgit,ygit)
	bass:drw_neck(xbss,ybss)
	keys:drw_keys(xkeya,ykeya)
	keys:drw_keys(xkeyb,ykeyb)
	keys:drw_pitch(1,xkeya,ykeya)
	keys:drw_pitch(2,xkeya,ykeya)
	keys:drw_pitch(3,xkeya,ykeya)
	keys:drw_pitch(8,xkeyb,ykeyb)
	guitar:drw_nts(8,xgit,ygit)
	bass:drw_nts(1,xbss,ybss)
	
		--score:d_all()
	--if track_tt<200 then cls() end
	--?"track_t : "..track_tt
	--drw_grph()
	
	drw_debug(8)
	input:rec(8)
	input:drw_keyin()
end



