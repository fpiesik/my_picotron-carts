--[[pod_format="raw",created="2025-04-01 09:03:08",modified="2025-05-12 15:41:17",revision=1213]]
guitar= {
	n_frts = 6, --number of frets
	n_actfr =4,
	n_strs = 6, -- number of strings
	tuning = {64,59,55,50,45,40},
	p_frts = {0,30,60,90,120,150,180}, --position of frets
	h_neck = {55,50},
	a={0,0,0,0,0,0,0,1}, --track is active
	non={0,0,0,0,0,0,0,0}, --note on
	pitch={0,0,0,0,0,0,0,0},
	frt={0,0,0,0,0,0,0,0},
	str={1,1,1,1,1,1,1,1},
	trnsp={0,0,0,0,0,0,0,0},
	upd=function(s,t)
		local strs=s.n_strs
		local frts=s.n_actfr
		local trnsp=s.trnsp[t]
		if track_p[t]!=255  and track_p[t]!=0 then
			s.non[t]=1
		else
			s.non[t]=0
		end
		if s.a[t]==1 and s.non[t]==1 then
			s.pitch[t] = track_p[t]
			--s.str[t]=strs
			s.str[t]=strs
			for str=strs,1,-1 do
				if s.pitch[t]>s.tuning[str]+trnsp+frts then 
					s.str[t]=str-1
				end 
				if s.str[t]<=0 then s.str[t]=1 end
				--if s.str[t]> s.n_strs then s.str[t]=s.n_strs end
			end
			s.frt[t]=s.pitch[t]-s.tuning[s.str[t]]-trnsp
		end
	end,
	drw_neck = function(s,x,y)
		strs = s.n_strs
		frts = s.n_frts
		cfrt = 6
		cwd = 4
		local strsp=s.h_neck[1]/strs
		for frt=1,frts do
			if (frt!=0) rectfill(x+s.p_frts[frt],y,x+s.p_frts[frt+1],y+s.h_neck[1],cwd)
			if (frt!=0) line(x+s.p_frts[frt],y,x+s.p_frts[frt],y+s.h_neck[1],cfrt)
		end
		for str=1,strs do
			line(x,y+str*strsp-strsp/2,x+s.p_frts[frts+1],y+str*strsp-strsp/2,7)
		end
	end, 
	drw_nts = function(s,t,x,y)
		local strs = s.n_strs
		local c = 7
		if s.a[t]==1 and s.non[t]==1 then
			local strsp=s.h_neck[1]/strs --calc string spacing
			if s.frt[t] >= 1 and s.frt[t] <= s.n_frts then 
					x = x+s.p_frts[s.frt[t]+1]
				elseif s.frt[t] >= s.n_frts then 
					x = x+s.p_frts[s.n_frts]
				else
					x = x
				end
			local y=y+s.str[t]*strsp-strsp/2
			local r=5
			circfill(x-r,y,r,3)
			circ(x-r,y,r,c)
			?s.frt[t],x-r-2,y-r+2,c
			--?s.str[t]
		end
	end,
}
