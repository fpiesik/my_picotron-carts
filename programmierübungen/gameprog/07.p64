:: main.lua
--[[pod_format="raw",created="2024-03-20 02:43:42",modified="2024-03-20 14:39:03",revision=311]]
--Variablen werden definiert:
p1_x=40 --p1_x steht fuer die X-Position des 1. Players.
p1_clr=6 --steht fuer die Farbe des ersten Spielers.

--Die Funktion "_draw" wird 30 mal in der Sekunde wiederholt:
function _draw()
	cls(0) --Loesche den Hintergrund und setze ihn auf die Farbe 0.
 	pset(p1_x,60,p1_clr) --Zeichne einen Pixel auf die Position x=p1_x und y=60.       
	if (btn(1)) p1_x=p1_x+1 --Bewege den Pixel nach rechts, indem x um 1 erhoet wird.        
end 

--Aufgaben:
--A1: Erweitere den Code so, dass der Pixel auch nach links gesteuert werden kann.
--A2: Der Pixel soll auch nach oben und unten gesteuert werden koennen.

