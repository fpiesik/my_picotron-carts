:: main.lua
--[[pod_format="raw",created="2024-03-20 02:43:42",modified="2024-03-22 22:17:06",revision=377]]
--Variablen werden definiert:
p1_x=40 --p1x steht fuer die X-Position des 1. Players. 
p1_y=40 --p1y steht fuer die Y-Position des 1. Players.
p1_clr=6 --steht fuer die Farbe des ersten Spielers.

function _draw()
	cls(0) --Loesche den Hintergrund und setze ihn auf die Farbe 0.
 	pset(p1_x,p1_y,p1_clr) --Pixel auf Position p1_x|p1_y mit der Farbe p1_clr.       
	if (btn(1)) p1_x=p1_x+1 --Pixel nach rechts, indem p1_x um 1 erhoet wird.  
	if (btn(0)) p1_x=p1_x-1 --Pixel nach links, indem p1_x um 1 erniedrigt wird. 
	if (btn(3)) p1_y=p1_y+1 --Pixel nach unten, indem p1_y um 1 erhoet wird.  
	if (btn(2)) p1_y=p1_y-1 --Pixel nach rechts, indem p1_y um 1 erniedrigt wird.	      
end 

--Aufgaben:
--A1:	Kommentiere Zeile 7 aus, indem du "--" davor schreibst. Beschreibe die Auswirkung. 
--    	Kannst du erklaeren, was passiert ist?
